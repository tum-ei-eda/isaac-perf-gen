/*********************************** Microaction Section ***********************************/
Connector {Pc, Pc_np, Pc_p}
Connector {Xa, Xb, Xd}

Resource {PCGen, Decoder, JumpDecoder, ALU, LSU, CSR}
Resource {MUL, MULH(5)}
Resource {DIV(divider), DIVU(divider_u)}
Resource {IPort_R, DPort_R, DPort_W}

// = XISAAC Resources =
virtual Resource {
    vCFU0_PUSH_WEIGHTS_I,
    vCFU0_PUSH_WEIGHTS_X,
    vCFU0_PUSH_WEIGHTS_O,
    vCFU0_SET_CODEBOOK_2B_I,
    vCFU0_SET_CODEBOOK_2B_X,
    vCFU0_SET_CODEBOOK_2B_O,
    vCFU0_SET_CODEBOOK_4B_I,
    vCFU0_SET_CODEBOOK_4B_X,
    vCFU0_SET_CODEBOOK_4B_O,
    vCFU0_SET_CODEBOOK_16B_I,
    vCFU0_SET_CODEBOOK_16B_X,
    vCFU0_SET_CODEBOOK_16B_O,
    vCFU0_ALU_MAC_I,
    vCFU0_ALU_MAC_X,
    vCFU0_ALU_MAC_O,
    vCFU0_ALU_RST_I,
    vCFU0_ALU_RST_X,
    vCFU0_ALU_RST_O,
    vCFU0_MAC_READ_I,
    vCFU0_MAC_READ_X,
