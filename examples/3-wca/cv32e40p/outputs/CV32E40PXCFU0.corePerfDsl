    vCFU0_MAC_READ_NO_RESET_I,
    vCFU0_MAC_READ_NO_RESET_X,
    vCFU0_MAC_READ_NO_RESET_O,
    vCFU0_DEBUG_DUMP_I,
    vCFU0_DEBUG_DUMP_X,
    vCFU0_DEBUG_DUMP_O
}

