/************************************ Stages & Pipeline ************************************/

Stage {
    EX_substage_CFU0_PUSH_WEIGHTS_I  (vuA_CFU0_PUSH_WEIGHTS_I),
    EX_substage_CFU0_PUSH_WEIGHTS_X  (vuA_CFU0_PUSH_WEIGHTS_X),
    EX_substage_CFU0_PUSH_WEIGHTS_O  (vuA_CFU0_PUSH_WEIGHTS_O),
    EX_substage_CFU0_SET_CODEBOOK_2B_I  (vuA_CFU0_SET_CODEBOOK_2B_I),
    EX_substage_CFU0_SET_CODEBOOK_2B_X  (vuA_CFU0_SET_CODEBOOK_2B_X),
    EX_substage_CFU0_SET_CODEBOOK_2B_O  (vuA_CFU0_SET_CODEBOOK_2B_O),
    EX_substage_CFU0_SET_CODEBOOK_4B_I  (vuA_CFU0_SET_CODEBOOK_4B_I),
    EX_substage_CFU0_SET_CODEBOOK_4B_X  (vuA_CFU0_SET_CODEBOOK_4B_X),
    EX_substage_CFU0_SET_CODEBOOK_4B_O  (vuA_CFU0_SET_CODEBOOK_4B_O),
    EX_substage_CFU0_SET_CODEBOOK_16B_I  (vuA_CFU0_SET_CODEBOOK_16B_I),
    EX_substage_CFU0_SET_CODEBOOK_16B_X  (vuA_CFU0_SET_CODEBOOK_16B_X),
    EX_substage_CFU0_SET_CODEBOOK_16B_O  (vuA_CFU0_SET_CODEBOOK_16B_O),
    EX_substage_CFU0_ALU_MAC_I  (vuA_CFU0_ALU_MAC_I),
    EX_substage_CFU0_ALU_MAC_X  (vuA_CFU0_ALU_MAC_X),
    EX_substage_CFU0_ALU_MAC_O  (vuA_CFU0_ALU_MAC_O),
    EX_substage_CFU0_ALU_RST_I  (vuA_CFU0_ALU_RST_I),
    EX_substage_CFU0_ALU_RST_X  (vuA_CFU0_ALU_RST_X),
    EX_substage_CFU0_ALU_RST_O  (vuA_CFU0_ALU_RST_O),
    EX_substage_CFU0_MAC_READ_I  (vuA_CFU0_MAC_READ_I),
    EX_substage_CFU0_MAC_READ_X  (vuA_CFU0_MAC_READ_X),
